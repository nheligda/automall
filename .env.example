# AUTOMALL Frontend Configuration

# Backend API Base URL
# Make sure Apache is running and PHP backend is accessible
VITE_API_BASE=http://localhost/automall%20proj/backend/public

# Shop Contact Information
VITE_SHOP_PHONE=+639091234567
VITE_SHOP_EMAIL=info@automall.com
VITE_SHOP_ADDRESS=123 Car Street, Manila, Philippines

# Feature Flags
VITE_DEBUG=true
VITE_ENABLE_OTW_NOTIFICATIONS=true

# Notification Settings
VITE_OTW_REMINDER_HOURS=2
VITE_HOLD_DURATION_HOURS=2
VITE_AUTO_REFRESH_INTERVAL_MS=30000

# API Configuration
VITE_API_TIMEOUT_MS=10000
VITE_MAX_RETRIES=3

# UI Configuration
VITE_ITEMS_PER_PAGE=12
VITE_APP_NAME=AUTOMALL
VITE_APP_TAGLINE=Your Digital Car Sales Platform

# Analytics (optional)
VITE_GA_ID=UA-XXXXXXXXX-X

# Environment
VITE_ENV=development
